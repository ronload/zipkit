{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "etl": "tsx scripts/etl.ts",
    "shadcn:diff": "for f in src/components/ui/*.tsx; do name=$(basename \"$f\" .tsx); echo \"=== $name ===\"; pnpm shadcn add \"$name\" --diff 2>&1 || pnpm shadcn add \"@mapcn/$name\" --diff 2>&1; echo; done",
    "shadcn:update": "for f in src/components/ui/*.tsx; do name=$(basename \"$f\" .tsx); pnpm shadcn add \"$name\" --overwrite 2>&1 || pnpm shadcn add \"@mapcn/$name\" --overwrite 2>&1; done"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@zipkit/core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.18.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "tailwindcss": "^4.3.1",
    "taiwan-atlas": "^2021.9.20",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
